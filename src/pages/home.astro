---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import products from '../data/products.json';

const base = import.meta.env.BASE_URL;

const webstoreUrl = 'https://pluginshop.link/elplugins';
const discordUrl = 'https://discord.com/invite/Fa4BdBvg2c';
const changelogUrl = 'https://discord.com/channels/764897214388240427/1080789983499145316';

const featureBlocks = [
  {
    icon: '🧩',
    title: 'RLPL',
    description: 'Free RuneLite based plugin loader included with all plugins.'
  },
  {
    icon: '⚙️',
    title: 'All Modes',
    description: 'Full Auto, Smart Click, One Click and Hotkey modes.'
  },
  {
    icon: '🚀',
    title: 'Jagex Launcher',
    description: 'All accounts supported.'
  },
  {
    icon: '📢',
    title: 'Frequent Updates',
    description: 'Check out our changelog on Discord.',
    link: changelogUrl,
    linkText: 'View Changelog'
  },
  {
    icon: '⏱️',
    title: 'Minimal Downtime',
    description: 'The Client is updated shortly after OSRS and RL updates.'
  },
  {
    icon: '📦',
    title: 'Simplified Packages',
    description: 'Choose from Plugin Package, PVM Plugins, or the full bundle.'
  },
  {
    icon: '🎛️',
    title: 'Fully Customisable',
    description: 'Delays and settings are fully customisable between plugins.'
  },
  {
    icon: '💬',
    title: 'Support',
    description: 'Help is available on Discord. Including FAQ, Support and Community Channels.'
  }
];
---

<BaseLayout
  title="Home - ElPlugins"
  description="ElPlugins full website homepage."
>
  <Navbar />

  <main>
    <section class="page-hero home-hero">
      <div class="home-hero-logo">
        <img src={`${base}images/elpluginshdlogo.png`} alt="ElPlugins logo" />
      </div>

      <p class="eyebrow">ElPlugins</p>
      <h1>For all your Old School Plugin needs</h1>
      <p>
        RuneLite plugins for Combat, Skilling, Minigames, Utility and PVM content.
        <br />
        Fully automated, Smart Click, One Click and Hotkey plugins available.
      </p>

      <div class="page-actions">
        <a class="button primary" href={webstoreUrl}>Purchase Plugins</a>
        <a class="button discord-button" href={discordUrl}>Join Discord</a>
        <a class="button secondary" href={`${base}plugins/`}>View Plugins</a>
      </div>
    </section>

    <section class="section packages-section">
      <div class="section-heading">
        <p class="eyebrow">Packages</p>
        <h2>Available Packages</h2>
        <p>Choose a Package from below. Crypto/GP handled through our Discord.</p>
      </div>

      <div class="package-grid aligned-package-grid">
        {products.map((product) => (
          <article class="package-card aligned-package-card">
            <div class="package-header">
              <div class="package-badge">{product.badge}</div>

              <div class="package-top">
                <span>{product.category}</span>
                <strong>{product.status}</strong>
              </div>

              <h3>{product.name}</h3>
              <p>{product.description}</p>
            </div>

            <div class="price-list aligned-price-list">
              {product.prices.map((price) => (
                <span>{price}</span>
              ))}
            </div>

            <ul class="aligned-feature-list">
              {product.features.map((feature) => (
                <li>{feature}</li>
              ))}
            </ul>

            <div class="card-actions aligned-card-actions">
              <a class="card-button" href={product.webstoreUrl}>Purchase Plugins</a>
              <a class="card-button muted" href={discordUrl}>Join Discord</a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section features-section">
      <div class="section-heading">
        <p class="eyebrow">Why ElPlugins</p>
        <h2>Built around support, updates and flexibility</h2>
      </div>

      <div class="feature-grid">
        {featureBlocks.map((feature) => (
          <article class="feature-card">
            <span class="feature-icon">{feature.icon}</span>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>

            {feature.link && (
              <a class="feature-link" href={feature.link}>{feature.linkText}</a>
            )}
          </article>
        ))}
      </div>
    </section>

    <section class="cta-section">
      <div>
        <p class="eyebrow">Get Started</p>
        <h2>Ready to browse the full catalogue?</h2>
        <p>
          View the plugin list, join Discord for help, or go straight to the webshop.
        </p>
      </div>

      <div class="cta-actions">
        <a class="button primary" href={webstoreUrl}>Purchase Plugins</a>
        <a class="button discord-button" href={discordUrl}>Join Discord</a>
        <a class="button secondary" href={`${base}plugins/`}>View Plugins</a>
      </div>
    </section>
  </main>

  <Footer />

  <style>
    .aligned-package-grid {
      align-items: stretch;
    }

    .aligned-package-card {
      display: grid;
      grid-template-rows: auto auto 1fr auto;
      min-height: 100%;
    }

    .package-header {
      display: grid;
      align-content: start;
    }

    .aligned-package-card .package-top {
      min-height: 34px;
    }

    .aligned-package-card h3 {
      min-height: 66px;
      display: flex;
      align-items: flex-start;
    }

    .aligned-package-card .package-header > p {
      min-height: 58px;
    }

    .aligned-price-list {
      align-self: start;
    }

    .aligned-price-list span {
      min-height: 46px;
      display: flex;
      align-items: center;
    }

    .aligned-feature-list {
      align-self: start;
      margin-bottom: 22px;
    }

    .aligned-card-actions {
      align-self: end;
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
      margin-top: 0;
    }

    .aligned-card-actions .card-button {
      width: 100%;
      min-height: 50px;
    }

    .feature-link {
      display: inline-flex;
      margin-top: 12px;
      color: #1b1100;
      background: linear-gradient(180deg, var(--gold-bright), var(--gold));
      border: 1px solid var(--border-strong);
      border-radius: 999px;
      padding: 9px 14px;
      font-size: 0.86rem;
      font-weight: 950;
      box-shadow: 0 12px 34px rgba(255, 216, 74, 0.2);
    }

    .feature-link:hover {
      transform: translateY(-2px);
      filter: brightness(1.08);
    }

    @media (min-width: 980px) {
      .aligned-card-actions {
        grid-template-columns: 1fr 1fr;
      }
    }
  </style>
</BaseLayout>