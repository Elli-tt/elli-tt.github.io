---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import pluginCatalogue from '../data/pluginCatalogue.json';

const base = import.meta.env.BASE_URL;

const discordUrl = 'https://discord.com/invite/Fa4BdBvg2c';
const webstoreUrl = 'https://pluginshop.link/elplugins';

const packageMap = {
  PVM: {
    name: 'PVM',
    icon: '⚔️',
    label: 'PVM Plugins'
  },
  Plugin: {
    name: 'Plugin',
    icon: '🎁',
    label: 'Plugin Package'
  }
};

function getPluginName(plugin) {
  if (typeof plugin === 'string') {
    return plugin;
  }

  if (plugin && typeof plugin === 'object') {
    return plugin.name || plugin.title || plugin.plugin || 'Unknown Plugin';
  }

  return 'Unknown Plugin';
}

function slugify(value) {
  return String(value)
    .toLowerCase()
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
}

function getPluginIcon(plugin, fallbackIcon) {
  if (plugin && typeof plugin === 'object') {
    return plugin.icon || plugin.emoji || plugin.logo || fallbackIcon;
  }

  return fallbackIcon;
}

function normalizeImageUrl(url) {
  if (!url) {
    return '';
  }

  return String(url)
    .replace('https://oldschool.runescape.wiki/images/Special:FilePath/', 'https://oldschool.runescape.wiki/w/Special:FilePath/')
    .replace('https://oldschool.runescape.wiki/wiki/Special:FilePath/', 'https://oldschool.runescape.wiki/w/Special:FilePath/');
}

function getPluginImage(plugin) {
  if (plugin && typeof plugin === 'object') {
    return normalizeImageUrl(plugin.image || plugin.imageUrl || '');
  }

  return '';
}

function getPluginSummary(plugin, name) {
  if (plugin && typeof plugin === 'object') {
    return plugin.summary || plugin.description || `${name} plugin for ElPlugins.`;
  }

  return `${name} plugin for ElPlugins.`;
}

const pluginList = pluginCatalogue
  .flatMap((category) => {
    const packageType = category.category === 'PVM' ? 'PVM' : 'Plugin';

    return category.plugins.map((plugin) => {
      const name = getPluginName(plugin);
      const slug = plugin && typeof plugin === 'object'
        ? plugin.slug || slugify(name)
        : slugify(name);

      return {
        name,
        icon: getPluginIcon(plugin, category.icon),
        image: getPluginImage(plugin),
        summary: getPluginSummary(plugin, name),
        slug,
        category: category.category,
        categoryDescription: category.description,
        packageType,
        packageIcon: packageMap[packageType].icon,
        packageLabel: packageMap[packageType].label
      };
    });
  })
  .sort((a, b) => a.name.localeCompare(b.name));

const categories = pluginCatalogue.map((category) => category.category);
---

<BaseLayout
  title="Plugins - ElPlugins"
  description="Browse ElPlugins Combat, Skilling, Minigames, Utility and PVM plugins."
>
  <Navbar />

  <main>
    <section class="page-hero">
      <p class="eyebrow">Plugin Catalogue</p>
      <h1>Browse Plugins</h1>
      <p>
        Search by plugin name, filter by category, or filter by package.
        Plugin Package items are marked with 🎁 and PVM Plugins are marked with ⚔️.
      </p>

      <div class="page-actions">
        <a class="button primary" href={webstoreUrl}>Purchase Plugins</a>
        <a class="button discord-button" href={discordUrl}>Join Discord</a>
      </div>
    </section>

    <section class="section plugin-browser-section">
      <div class="plugin-controls" aria-label="Plugin filters">
        <label>
          <span>Search</span>
          <input
            id="pluginSearch"
            type="search"
            placeholder="Search plugins..."
            autocomplete="off"
          />
        </label>

        <label>
          <span>Category</span>
          <select id="categoryFilter">
            <option value="all">All Categories</option>
            {categories.map((category) => (
              <option value={category}>{category}</option>
            ))}
          </select>
        </label>

        <label>
          <span>Package</span>
          <select id="packageFilter">
            <option value="all">Both Packages</option>
            <option value="Plugin">🎁 Plugin Package</option>
            <option value="PVM">⚔️ PVM Plugins</option>
          </select>
        </label>
      </div>

      <div class="plugin-result-meta">
        <p><strong id="pluginCount">0</strong> plugins shown</p>
        <button id="clearFilters" type="button">Clear Filters</button>
      </div>

      <section class="selected-category-heading" id="selectedCategoryHeading" hidden>
        <div>
          <p class="eyebrow" id="selectedCategoryPackage">Plugin Catalogue</p>
          <h2 id="selectedCategoryTitle">All Plugins</h2>
          <p id="selectedCategoryDescription">
            Full plugin list sorted alphabetically.
          </p>
        </div>

        <span id="selectedCategoryCount">0 Plugins</span>
      </section>

      <div class="plugin-card-grid" id="pluginGrid">
        {pluginList.map((plugin) => (
          <article
            class="plugin-showcase-card"
            data-plugin-card
            data-name={plugin.name.toLowerCase()}
            data-category={plugin.category}
            data-category-description={plugin.categoryDescription}
            data-package={plugin.packageType}
            data-package-label={plugin.packageLabel}
            data-package-icon={plugin.packageIcon}
          >
            <div class="plugin-card-image">
              {plugin.image ? (
                <img src={plugin.image} alt={`${plugin.name} image`} loading="lazy" />
              ) : (
                <div class="plugin-card-fallback">{plugin.icon}</div>
              )}

              <span
                class={`package-marker ${plugin.packageType === 'PVM' ? 'pvm-marker' : 'plugin-marker'}`}
                title={plugin.packageLabel}
                aria-label={plugin.packageLabel}
              >
                {plugin.packageIcon}
              </span>
            </div>

            <div class="plugin-card-body">
              <div class="plugin-card-title-row">
                <span class="plugin-emoji" aria-hidden="true">{plugin.icon}</span>
                <h3>{plugin.name}</h3>
              </div>

              <p>{plugin.summary}</p>

              <a class="plugin-details-button" href={`${base}plugins/${plugin.slug}/`}>
                View Details
              </a>
            </div>
          </article>
        ))}
      </div>

      <div class="no-results" id="noResults" hidden>
        <h2>No plugins found</h2>
        <p>Try clearing the filters or searching for a different plugin name.</p>
      </div>
    </section>

    <section class="section center plugin-help-section">
      <div class="section-heading plugin-help-heading">
        <p class="eyebrow">Need Help?</p>
        <h2>Join Discord for package help</h2>
        <p>
          Ask questions, check compatibility, and get help choosing the right package.
        </p>
      </div>

      <div class="bottom-cta">
        <a class="button discord-button" href={discordUrl}>Join Discord</a>
        <a class="button primary" href={webstoreUrl}>Purchase Plugins</a>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    const searchInput = document.querySelector('#pluginSearch');
    const categoryFilter = document.querySelector('#categoryFilter');
    const packageFilter = document.querySelector('#packageFilter');
    const clearFilters = document.querySelector('#clearFilters');
    const pluginCount = document.querySelector('#pluginCount');
    const noResults = document.querySelector('#noResults');

    const selectedCategoryHeading = document.querySelector('#selectedCategoryHeading');
    const selectedCategoryPackage = document.querySelector('#selectedCategoryPackage');
    const selectedCategoryTitle = document.querySelector('#selectedCategoryTitle');
    const selectedCategoryDescription = document.querySelector('#selectedCategoryDescription');
    const selectedCategoryCount = document.querySelector('#selectedCategoryCount');

    const cards = Array.from(document.querySelectorAll('[data-plugin-card]'));

    function updateSelectedCategoryHeading(visibleCount) {
      const categoryValue = categoryFilter.value;

      if (categoryValue === 'all') {
        selectedCategoryHeading.hidden = true;
        return;
      }

      const matchingCard = cards.find((card) => card.dataset.category === categoryValue);
      const packageIcon = matchingCard?.dataset.packageIcon || '';
      const packageLabel = matchingCard?.dataset.packageLabel || 'Plugin Catalogue';
      const description = matchingCard?.dataset.categoryDescription || '';

      selectedCategoryPackage.textContent = `${packageIcon} ${packageLabel}`;
      selectedCategoryTitle.textContent = categoryValue;
      selectedCategoryDescription.textContent = description;
      selectedCategoryCount.textContent = `${visibleCount} Plugin${visibleCount === 1 ? '' : 's'}`;

      selectedCategoryHeading.hidden = false;
    }

    function updateFilters() {
      const searchValue = searchInput.value.trim().toLowerCase();
      const categoryValue = categoryFilter.value;
      const packageValue = packageFilter.value;

      let visibleCount = 0;

      cards.forEach((card) => {
        const name = card.dataset.name || '';
        const category = card.dataset.category || '';
        const packageType = card.dataset.package || '';

        const matchesSearch = !searchValue || name.includes(searchValue);
        const matchesCategory = categoryValue === 'all' || category === categoryValue;
        const matchesPackage = packageValue === 'all' || packageType === packageValue;

        const isVisible = matchesSearch && matchesCategory && matchesPackage;

        card.hidden = !isVisible;

        if (isVisible) {
          visibleCount += 1;
        }
      });

      pluginCount.textContent = String(visibleCount);
      noResults.hidden = visibleCount !== 0;

      updateSelectedCategoryHeading(visibleCount);
    }

    searchInput.addEventListener('input', updateFilters);
    categoryFilter.addEventListener('change', updateFilters);
    packageFilter.addEventListener('change', updateFilters);

    clearFilters.addEventListener('click', () => {
      searchInput.value = '';
      categoryFilter.value = 'all';
      packageFilter.value = 'all';
      updateFilters();
      searchInput.focus();
    });

    updateFilters();
  </script>

  <style>
    .plugin-browser-section {
      padding-top: 46px;
    }

    .plugin-controls {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 16px;
      margin-bottom: 20px;
      padding: 22px;
      background:
        radial-gradient(circle at top right, rgba(255, 216, 74, 0.12), transparent 18rem),
        linear-gradient(180deg, rgba(36, 31, 19, 0.88), rgba(16, 14, 9, 0.95));
      border: 1px solid var(--border);
      border-radius: 28px;
      box-shadow: var(--shadow);
    }

    .plugin-controls label {
      display: grid;
      gap: 8px;
      color: var(--gold-bright);
      font-size: 0.78rem;
      font-weight: 950;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .plugin-controls input,
    .plugin-controls select {
      width: 100%;
      min-height: 52px;
      padding: 0 16px;
      color: var(--text);
      background: rgba(5, 4, 3, 0.72);
      border: 1px solid rgba(255, 216, 74, 0.24);
      border-radius: 16px;
      outline: none;
      font: inherit;
      font-weight: 800;
    }

    .plugin-controls input:focus,
    .plugin-controls select:focus {
      border-color: var(--gold-bright);
      box-shadow: 0 0 0 4px rgba(255, 216, 74, 0.12);
    }

    .plugin-result-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 28px;
      color: var(--muted);
    }

    .plugin-result-meta p {
      margin: 0;
    }

    .plugin-result-meta strong {
      color: var(--gold-bright);
    }

    .plugin-result-meta button {
      cursor: pointer;
      color: #1b1100;
      background: linear-gradient(180deg, var(--gold-bright), var(--gold));
      border: 1px solid var(--border-strong);
      border-radius: 999px;
      padding: 10px 16px;
      font: inherit;
      font-weight: 950;
    }

    .selected-category-heading {
      display: flex;
      align-items: end;
      justify-content: space-between;
      gap: 20px;
      margin-bottom: 26px;
      border-bottom: 1px solid var(--border);
      padding-bottom: 16px;
    }

    .selected-category-heading h2 {
      margin-bottom: 8px;
    }

    .selected-category-heading p {
      max-width: 760px;
      color: var(--muted);
      line-height: 1.65;
    }

    .selected-category-heading .eyebrow {
      color: var(--gold-bright);
    }

    .selected-category-heading > span {
      color: var(--gold-bright);
      font-weight: 900;
      white-space: nowrap;
    }

    .plugin-card-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 22px;
    }

    .plugin-showcase-card {
      overflow: hidden;
      background:
        linear-gradient(180deg, rgba(36, 31, 19, 0.9), rgba(16, 14, 9, 0.96));
      border: 1px solid var(--border);
      border-radius: 28px;
      box-shadow: var(--shadow);
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        box-shadow 160ms ease;
    }

    .plugin-showcase-card:hover {
      transform: translateY(-4px);
      border-color: var(--border-strong);
      box-shadow:
        0 24px 70px rgba(0, 0, 0, 0.5),
        0 0 42px rgba(255, 216, 74, 0.12);
    }

    .plugin-card-image {
      position: relative;
      height: 210px;
      overflow: hidden;
      background:
        radial-gradient(circle at center, rgba(255, 216, 74, 0.13), transparent 18rem),
        #11100b;
    }

    .plugin-card-image::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, transparent 30%, rgba(5, 4, 3, 0.76) 100%);
      pointer-events: none;
    }

    .plugin-card-image img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      padding: 22px;
      display: block;
      background:
        radial-gradient(circle at center, rgba(255, 216, 74, 0.1), transparent 17rem),
        #11100b;
    }

    .plugin-card-fallback {
      height: 100%;
      display: grid;
      place-items: center;
      font-size: 5rem;
    }

    .package-marker {
      position: absolute;
      top: 16px;
      right: 16px;
      z-index: 2;
      display: grid;
      place-items: center;
      width: 48px;
      height: 48px;
      border-radius: 16px;
      font-size: 1.55rem;
      border: 1px solid rgba(255, 216, 74, 0.34);
      background: rgba(5, 4, 3, 0.78);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        0 16px 34px rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(10px);
    }

    .pvm-marker {
      border-color: rgba(233, 237, 240, 0.38);
      background: rgba(5, 4, 3, 0.78);
    }

    .plugin-card-body {
      padding: 22px;
      display: grid;
      gap: 14px;
    }

    .plugin-card-title-row {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .plugin-card-title-row h3 {
      font-size: 1.28rem;
      overflow-wrap: anywhere;
    }

    .plugin-emoji {
      flex: 0 0 auto;
      display: grid;
      place-items: center;
      width: 42px;
      height: 42px;
      border-radius: 14px;
      font-size: 1.4rem;
      line-height: 1;
      background: rgba(255, 216, 74, 0.08);
      border: 1px solid rgba(255, 216, 74, 0.16);
    }

    .plugin-card-body p {
      margin: 0;
      color: var(--muted);
      line-height: 1.62;
    }

    .plugin-details-button {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      margin-top: 6px;
      color: var(--text);
      font-weight: 950;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: rgba(255, 216, 74, 0.08);
      transition:
        transform 160ms ease,
        border-color 160ms ease,
        background 160ms ease;
    }

    .plugin-details-button:hover {
      transform: translateY(-2px);
      border-color: var(--border-strong);
      background: rgba(255, 216, 74, 0.14);
    }

    .no-results {
      padding: 34px;
      text-align: center;
      background:
        linear-gradient(180deg, rgba(36, 31, 19, 0.88), rgba(16, 14, 9, 0.95));
      border: 1px solid var(--border);
      border-radius: 28px;
      box-shadow: var(--shadow);
    }

    .no-results h2 {
      margin-top: 0;
    }

    .no-results p {
      color: var(--muted);
    }

    .plugin-help-section {
      display: grid;
      justify-items: center;
      text-align: center;
    }

    .plugin-help-heading {
      display: grid;
      justify-items: center;
      text-align: center;
    }

    .plugin-help-heading p {
      margin-left: auto;
      margin-right: auto;
    }

    [hidden] {
      display: none !important;
    }

    @media (max-width: 1180px) {
      .plugin-card-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 980px) {
      .plugin-controls {
        grid-template-columns: 1fr;
      }

      .plugin-result-meta,
      .selected-category-heading {
        align-items: flex-start;
        flex-direction: column;
      }
    }

    @media (max-width: 720px) {
      .plugin-card-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</BaseLayout>