---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import pluginCatalogue from '../../data/pluginCatalogue.json';

const base = import.meta.env.BASE_URL;

const discordUrl = 'https://discord.com/invite/Fa4BdBvg2c';
const webstoreUrl = 'https://pluginshop.link/elplugins';

export function getStaticPaths() {
  const packageMap = {
    PVM: {
      name: 'PVM',
      icon: '⚔️',
      label: 'PVM Plugins'
    },
    Plugin: {
      name: 'Plugin',
      icon: '🎁',
      label: 'Plugin Package'
    }
  };

  function slugify(value) {
    return String(value)
      .toLowerCase()
      .replace(/&/g, 'and')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)/g, '');
  }

  function normalizeImageUrl(url) {
    if (!url) {
      return '';
    }

    return String(url)
      .replace('https://oldschool.runescape.wiki/images/Special:FilePath/', 'https://oldschool.runescape.wiki/w/Special:FilePath/')
      .replace('https://oldschool.runescape.wiki/wiki/Special:FilePath/', 'https://oldschool.runescape.wiki/w/Special:FilePath/');
  }

  function getPluginName(plugin) {
    if (typeof plugin === 'string') {
      return plugin;
    }

    if (plugin && typeof plugin === 'object') {
      return plugin.name || plugin.title || plugin.plugin || 'Unknown Plugin';
    }

    return 'Unknown Plugin';
  }

  function getPluginIcon(plugin, fallbackIcon) {
    if (plugin && typeof plugin === 'object') {
      return plugin.icon || plugin.emoji || plugin.logo || fallbackIcon;
    }

    return fallbackIcon;
  }

  function getPluginImage(plugin) {
    if (plugin && typeof plugin === 'object') {
      return normalizeImageUrl(plugin.image || plugin.imageUrl || '');
    }

    return '';
  }

  function getPluginSummary(plugin, name) {
    if (plugin && typeof plugin === 'object') {
      return plugin.summary || plugin.description || `${name} plugin for ElPlugins.`;
    }

    return `${name} plugin for ElPlugins.`;
  }

  function getPluginDetails(plugin, name) {
    if (plugin && typeof plugin === 'object') {
      return plugin.details || `Write your ${name} details here.`;
    }

    return `Write your ${name} details here.`;
  }

  const plugins = pluginCatalogue.flatMap((category) => {
    const packageType = category.category === 'PVM' ? 'PVM' : 'Plugin';

    return category.plugins.map((plugin) => {
      const name = getPluginName(plugin);
      const slug = plugin && typeof plugin === 'object'
        ? plugin.slug || slugify(name)
        : slugify(name);

      return {
        name,
        slug,
        icon: getPluginIcon(plugin, category.icon),
        image: getPluginImage(plugin),
        summary: getPluginSummary(plugin, name),
        details: getPluginDetails(plugin, name),
        category: category.category,
        categoryDescription: category.description,
        packageType,
        packageIcon: packageMap[packageType].icon,
        packageLabel: packageMap[packageType].label
      };
    });
  });

  return plugins.map((plugin) => ({
    params: {
      slug: plugin.slug
    },
    props: {
      plugin
    }
  }));
}

const { plugin } = Astro.props;
---

<BaseLayout
  title={`${plugin.name} - ElPlugins`}
  description={plugin.summary}
>
  <Navbar />

  <main>
    <section class="plugin-detail-hero">
      <a class="back-link" href={`${base}plugins/`}>← Back to Plugins</a>

      <div class="plugin-detail-grid">
        <div class="plugin-detail-image">
          {plugin.image ? (
            <img src={plugin.image} alt={`${plugin.name} image`} />
          ) : (
            <div class="plugin-detail-fallback">{plugin.icon}</div>
          )}

          <span class="detail-package-marker">
            {plugin.packageIcon} {plugin.packageLabel}
          </span>
        </div>

        <div class="plugin-detail-content">
          <p class="eyebrow">{plugin.category}</p>
          <h1>{plugin.name}</h1>
          <p>{plugin.summary}</p>

          <article class="plugin-detail-card plugin-detail-inline-card">
            <p class="eyebrow">Plugin Details</p>
            <h2>About {plugin.name}</h2>
            <p>{plugin.details}</p>
          </article>

          <div class="detail-meta">
            <span>{plugin.icon} {plugin.category}</span>
            <span>{plugin.packageIcon} {plugin.packageLabel}</span>
          </div>

          <div class="page-actions">
            <a class="button primary" href={webstoreUrl}>Purchase Plugins</a>
            <a class="button discord-button" href={discordUrl}>Join Discord</a>
          </div>
        </div>
      </div>
    </section>

    <section class="plugin-detail-body">
      <article class="plugin-detail-card">
        <p class="eyebrow">Package</p>
        <h2>{plugin.packageLabel}</h2>
        <p>
          This plugin is included in the {plugin.packageLabel}. For package questions,
          purchase help, Crypto/GP payments or setup support, join Discord.
        </p>
      </article>
    </section>
  </main>

  <Footer />

  <style>
    .plugin-detail-hero {
      padding: 54px 6vw 70px;
      border-bottom: 1px solid var(--border);
      background:
        radial-gradient(circle at 18% 0%, rgba(255, 216, 74, 0.16), transparent 30rem),
        radial-gradient(circle at 82% 0%, rgba(25, 255, 98, 0.1), transparent 32rem);
    }

    .back-link {
      display: inline-flex;
      margin-bottom: 28px;
      color: var(--gold-bright);
      font-weight: 950;
    }

    .plugin-detail-grid {
      display: grid;
      grid-template-columns: minmax(320px, 520px) 1fr;
      gap: 42px;
      align-items: start;
    }

    .plugin-detail-image {
      position: relative;
      overflow: hidden;
      min-height: 420px;
      border: 1px solid var(--border);
      border-radius: 32px;
      background:
        radial-gradient(circle at center, rgba(255, 216, 74, 0.13), transparent 18rem),
        #11100b;
      box-shadow: var(--shadow);
    }

    .plugin-detail-image::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, transparent 38%, rgba(5, 4, 3, 0.72) 100%);
      pointer-events: none;
    }

    .plugin-detail-image img {
      width: 100%;
      height: 100%;
      min-height: 420px;
      object-fit: contain;
      padding: 28px;
      display: block;
      background:
        radial-gradient(circle at center, rgba(255, 216, 74, 0.1), transparent 17rem),
        #11100b;
    }

    .plugin-detail-fallback {
      min-height: 420px;
      display: grid;
      place-items: center;
      font-size: 7rem;
    }

    .detail-package-marker {
      position: absolute;
      left: 20px;
      bottom: 20px;
      z-index: 2;
      padding: 11px 15px;
      border: 1px solid var(--border);
      border-radius: 999px;
      color: var(--text);
      background: rgba(5, 4, 3, 0.78);
      font-weight: 950;
      backdrop-filter: blur(10px);
    }

    .plugin-detail-content {
      display: grid;
      align-content: start;
      gap: 22px;
    }

    .plugin-detail-content h1 {
      margin-bottom: 0;
    }

    .plugin-detail-content > p:not(.eyebrow) {
      max-width: 720px;
      margin: 0;
      color: var(--muted);
      font-size: 1.14rem;
      line-height: 1.72;
    }

    .detail-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .detail-meta span {
      padding: 10px 14px;
      color: var(--text);
      background: rgba(255, 216, 74, 0.08);
      border: 1px solid var(--border);
      border-radius: 999px;
      font-weight: 900;
    }

    .plugin-detail-body {
      padding: 70px 6vw 90px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 22px;
      max-width: 920px;
    }

    .plugin-detail-card {
      padding: 30px;
      background:
        radial-gradient(circle at top right, rgba(255, 216, 74, 0.09), transparent 18rem),
        linear-gradient(180deg, rgba(36, 31, 19, 0.88), rgba(16, 14, 9, 0.95));
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .plugin-detail-inline-card {
      margin-top: 4px;
    }

    .plugin-detail-card h2 {
      margin-top: 8px;
    }

    .plugin-detail-card p:not(.eyebrow) {
      color: var(--muted);
      line-height: 1.72;
    }

    @media (max-width: 980px) {
      .plugin-detail-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      .plugin-detail-hero,
      .plugin-detail-body {
        padding-left: 22px;
        padding-right: 22px;
      }

      .plugin-detail-image,
      .plugin-detail-image img,
      .plugin-detail-fallback {
        min-height: 320px;
      }
    }
  </style>
</BaseLayout>