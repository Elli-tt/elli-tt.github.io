---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const discordUrl = 'https://discord.com/invite/Fa4BdBvg2c';

const faqs = [
  {
    question: 'Where can I find more information?',
    answer: 'You can find more information on the Discord Server, not on the Website. The Discord includes FAQ, support channels, community help, updates and package information.'
  },
  {
    question: 'Where do I get support?',
    answer: 'Support is handled through Discord. Join the server and use the available support or ticket channels.'
  },
  {
    question: 'Where is Crypto/GP handled?',
    answer: 'Crypto and GP payments are handled through Discord. Join the server for help with those payment methods.'
  },
  {
    question: 'Where can I buy plugins?',
    answer: 'You can purchase through the webshop. For questions before purchase, join Discord first.'
  },
  {
    question: 'Which package do I need?',
    answer: 'The Plugin Package covers Combat, Skilling, Minigames and Utility plugins. PVM Plugins covers the listed PVM plugins. The Plugin & PVM Package includes both.'
  },
  {
    question: 'Is help available after purchase?',
    answer: 'Yes. Help is available on Discord, including FAQ, support and community channels.'
  }
];
---

<BaseLayout
  title="FAQ - ElPlugins"
  description="Frequently asked questions for ElPlugins."
>
  <Navbar />

  <main>
    <section class="page-hero">
      <p class="eyebrow">FAQ</p>
      <h1>Frequently Asked Questions</h1>
      <p>
        Most detailed information is available on the Discord Server, including
        support, package help, updates, changelogs and community channels.
      </p>

      <div class="page-actions">
        <a class="button discord-button" href={discordUrl}>Join Discord</a>
      </div>
    </section>

    <section class="faq-list">
      {faqs.map((faq) => (
        <article>
          <h2>{faq.question}</h2>
          <p>{faq.answer}</p>
        </article>
      ))}
    </section>

    <section class="section center">
      <div class="section-heading">
        <p class="eyebrow">Still Need Help?</p>
        <h2>Join the Discord Server</h2>
        <p>
          The website only contains basic information. The Discord Server is the best place
          to find more details, ask questions, read updates and get support.
        </p>
      </div>

      <div class="bottom-cta">
        <a class="button discord-button" href={discordUrl}>Join Discord</a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>