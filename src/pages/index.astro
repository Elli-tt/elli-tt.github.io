---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const webstoreUrl = 'https://pluginshop.link/elplugins';
const discordUrl = 'https://discord.com/invite/Fa4BdBvg2c';
const mainSiteUrl = 'https://elli-tt.github.io/';
---

<BaseLayout
  title="ElPlugins - Old School RuneLite Plugins"
  description="ElPlugins - For all your Old School Plugin needs."
>
  <Navbar splash={true} />

  <main>
    <section class="splash-hero">
      <div class="splash-glow"></div>

      <div class="splash-logo-wrap">
        <img src={`${base}images/elplugins.png`} alt="ElPlugins logo" class="splash-logo" />
      </div>

      <div class="splash-content">
        <h1>ElPlugins</h1>

        <div class="splash-buttons">
          <a class="splash-button purchase" href={webstoreUrl}>
            <span class="splash-button-logo">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M7 18.5A1.5 1.5 0 1 0 7 21.5A1.5 1.5 0 0 0 7 18.5ZM17 18.5A1.5 1.5 0 1 0 17 21.5A1.5 1.5 0 0 0 17 18.5ZM4.2 4H2V2H5.8L6.4 5H22L19.8 15.2C19.6 16.2 18.7 17 17.6 17H8.2C7.1 17 6.2 16.2 6 15.1L4.2 4ZM6.8 7L8.2 15H17.6L19.2 7H6.8Z" />
              </svg>
            </span>

            <span class="splash-button-content">
              <strong>Purchase Plugins</strong>
              <span>Visit the Webshop</span>
            </span>

            <span class="splash-button-arrow">→</span>
          </a>

          <a class="splash-button discord" href={discordUrl}>
            <span class="splash-button-logo">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M19.5 5.2C18.1 4.5 16.7 4.1 15.2 4L15 4.4C16.3 4.7 17 5.1 17.8 5.6C16.1 4.8 14.5 4.5 12.9 4.5H11.1C9.5 4.5 7.9 4.8 6.2 5.6C7 5.1 7.8 4.7 9 4.4L8.8 4C7.3 4.1 5.9 4.5 4.5 5.2C1.7 9.3 1 13.3 1.4 17.2C3.1 18.5 4.8 19.2 6.5 19.7L7.4 18.2C6.9 18 6.4 17.8 5.9 17.5C6.1 17.4 6.2 17.3 6.4 17.2C10 18.8 14 18.8 17.6 17.2C17.8 17.3 17.9 17.4 18.1 17.5C17.6 17.8 17.1 18 16.6 18.2L17.5 19.7C19.2 19.2 20.9 18.5 22.6 17.2C23.1 12.7 21.8 8.8 19.5 5.2ZM8.6 14.7C7.7 14.7 7 13.9 7 13C7 12.1 7.7 11.3 8.6 11.3C9.5 11.3 10.2 12.1 10.2 13C10.2 13.9 9.5 14.7 8.6 14.7ZM15.4 14.7C14.5 14.7 13.8 13.9 13.8 13C13.8 12.1 14.5 11.3 15.4 11.3C16.3 11.3 17 12.1 17 13C17 13.9 16.3 14.7 15.4 14.7Z" />
              </svg>
            </span>

            <span class="splash-button-content">
              <strong>Join Discord</strong>
              <span>Home of ElPlugins</span>
            </span>

            <span class="splash-button-arrow">→</span>
          </a>

          <a class="splash-button website" href={mainSiteUrl}>
            <span class="splash-button-logo">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2A10 10 0 1 0 12 22A10 10 0 0 0 12 2ZM18.9 8H15.9C15.6 6.8 15.2 5.7 14.6 4.8C16.4 5.4 17.9 6.5 18.9 8ZM12 4.1C12.8 5.2 13.4 6.5 13.8 8H10.2C10.6 6.5 11.2 5.2 12 4.1ZM4.3 14C4.1 13.4 4 12.7 4 12C4 11.3 4.1 10.6 4.3 10H7.7C7.6 10.7 7.5 11.3 7.5 12C7.5 12.7 7.6 13.3 7.7 14H4.3ZM5.1 16H8.1C8.4 17.2 8.8 18.3 9.4 19.2C7.6 18.6 6.1 17.5 5.1 16ZM8.1 8H5.1C6.1 6.5 7.6 5.4 9.4 4.8C8.8 5.7 8.4 6.8 8.1 8ZM12 19.9C11.2 18.8 10.6 17.5 10.2 16H13.8C13.4 17.5 12.8 18.8 12 19.9ZM14.2 14H9.8C9.6 13.3 9.5 12.7 9.5 12C9.5 11.3 9.6 10.7 9.8 10H14.2C14.4 10.7 14.5 11.3 14.5 12C14.5 12.7 14.4 13.3 14.2 14ZM14.6 19.2C15.2 18.3 15.6 17.2 15.9 16H18.9C17.9 17.5 16.4 18.6 14.6 19.2ZM16.3 14C16.4 13.3 16.5 12.7 16.5 12C16.5 11.3 16.4 10.7 16.3 10H19.7C19.9 10.6 20 11.3 20 12C20 12.7 19.9 13.4 19.7 14H16.3Z" />
              </svg>
            </span>

            <span class="splash-button-content">
              <strong>View Website</strong>
              <span>Continue to the Full Site</span>
            </span>

            <span class="splash-button-arrow">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>