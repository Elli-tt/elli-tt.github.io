---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL;

const webstoreUrl = 'https://pluginshop.link/elplugins';
const discordUrl = 'https://discord.com/invite/Fa4BdBvg2c';
const homeUrl = `${base}home/`;
---

<BaseLayout
  title="ElPlugins - Old School RuneLite Plugins"
  description="ElPlugins - For all your Old School Plugin needs."
>
  <Navbar splash={true} />

  <main>
    <section class="splash-hero ocean-splash">
      <div class="splash-glow"></div>

      <div class="bubble bubble-one"></div>
      <div class="bubble bubble-two"></div>
      <div class="bubble bubble-three"></div>
      <div class="bubble bubble-four"></div>

      <div class="splash-logo-wrap ocean-logo-wrap">
        <img src={`${base}images/elpluginshdlogo.png`} alt="ElPlugins logo" class="splash-logo ocean-logo" />
      </div>

      <div class="splash-content ocean-splash-content">
        <p class="splash-tagline">
          For all your Old School Plugin needs
        </p>

        <p class="splash-subtagline">
          Combat <span>•</span> Skilling <span>•</span> Minigames <span>•</span> Utility <span>•</span> PVM
        </p>

        <div class="splash-buttons">
          <a class="splash-button purchase" href={webstoreUrl}>
            <span class="splash-button-logo">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M7 18.5A1.5 1.5 0 1 0 7 21.5A1.5 1.5 0 0 0 7 18.5ZM17 18.5A1.5 1.5 0 1 0 17 21.5A1.5 1.5 0 0 0 17 18.5ZM4.2 4H2V2H5.8L6.4 5H22L19.8 15.2C19.6 16.2 18.7 17 17.6 17H8.2C7.1 17 6.2 16.2 6 15.1L4.2 4ZM6.8 7L8.2 15H17.6L19.2 7H6.8Z" />
              </svg>
            </span>

            <span class="splash-button-content">
              <strong>Purchase Plugins</strong>
              <span>Visit the Webshop</span>
            </span>

            <span class="splash-button-arrow">→</span>
          </a>

          <a class="splash-button discord" href={discordUrl}>
            <span class="splash-button-logo">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M19.5 5.2C18.1 4.5 16.7 4.1 15.2 4L15 4.4C16.3 4.7 17 5.1 17.8 5.6C16.1 4.8 14.5 4.5 12.9 4.5H11.1C9.5 4.5 7.9 4.8 6.2 5.6C7 5.1 7.8 4.7 9 4.4L8.8 4C7.3 4.1 5.9 4.5 4.5 5.2C1.7 9.3 1 13.3 1.4 17.2C3.1 18.5 4.8 19.2 6.5 19.7L7.4 18.2C6.9 18 6.4 17.8 5.9 17.5C6.1 17.4 6.2 17.3 6.4 17.2C10 18.8 14 18.8 17.6 17.2C17.8 17.3 17.9 17.4 18.1 17.5C17.6 17.8 17.1 18 16.6 18.2L17.5 19.7C19.2 19.2 20.9 18.5 22.6 17.2C23.1 12.7 21.8 8.8 19.5 5.2ZM8.6 14.7C7.7 14.7 7 13.9 7 13C7 12.1 7.7 11.3 8.6 11.3C9.5 11.3 10.2 12.1 10.2 13C10.2 13.9 9.5 14.7 8.6 14.7ZM15.4 14.7C14.5 14.7 13.8 13.9 13.8 13C13.8 12.1 14.5 11.3 15.4 11.3C16.3 11.3 17 12.1 17 13C17 13.9 16.3 14.7 15.4 14.7Z" />
              </svg>
            </span>

            <span class="splash-button-content">
              <strong>Join Discord</strong>
              <span>Home of ElPlugins</span>
            </span>

            <span class="splash-button-arrow">→</span>
          </a>

          <a class="splash-button website" href={homeUrl}>
            <span class="splash-button-logo">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 2A10 10 0 1 0 12 22A10 10 0 0 0 12 2ZM18.9 8H15.9C15.6 6.8 15.2 5.7 14.6 4.8C16.4 5.4 17.9 6.5 18.9 8ZM12 4.1C12.8 5.2 13.4 6.5 13.8 8H10.2C10.6 6.5 11.2 5.2 12 4.1ZM4.3 14C4.1 13.4 4 12.7 4 12C4 11.3 4.1 10.6 4.3 10H7.7C7.6 10.7 7.5 11.3 7.5 12C7.5 12.7 7.6 13.3 7.7 14H4.3ZM5.1 16H8.1C8.4 17.2 8.8 18.3 9.4 19.2C7.6 18.6 6.1 17.5 5.1 16ZM8.1 8H5.1C6.1 6.5 7.6 5.4 9.4 4.8C8.8 5.7 8.4 6.8 8.1 8ZM12 19.9C11.2 18.8 10.6 17.5 10.2 16H13.8C13.4 17.5 12.8 18.8 12 19.9ZM14.2 14H9.8C9.6 13.3 9.5 12.7 9.5 12C9.5 11.3 9.6 10.7 9.8 10H14.2C14.4 10.7 14.5 11.3 14.5 12C14.5 12.7 14.4 13.3 14.2 14ZM14.6 19.2C15.2 18.3 15.6 17.2 15.9 16H18.9C17.9 17.5 16.4 18.6 14.6 19.2ZM16.3 14C16.4 13.3 16.5 12.7 16.5 12C16.5 11.3 16.4 10.7 16.3 10H19.7C19.9 10.6 20 11.3 20 12C20 12.7 19.9 13.4 19.7 14H16.3Z" />
              </svg>
            </span>

            <span class="splash-button-content">
              <strong>View Website</strong>
              <span>To the Full Site</span>
            </span>

            <span class="splash-button-arrow">→</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <style>
    main {
      display: block;
    }

    .ocean-splash {
      min-height: auto;
      padding-top: 18px;
      padding-bottom: 18px;
      align-content: start;
      grid-template-rows: auto auto;
      gap: 0;
      overflow: hidden;
    }

    .ocean-splash::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 50% 14%, rgba(255, 216, 74, 0.055), transparent 18rem),
        radial-gradient(circle at 48% 34%, rgba(25, 255, 98, 0.045), transparent 24rem);
      animation: oceanLightDrift 12s ease-in-out infinite;
    }

    .ocean-logo-wrap {
      margin-top: 0;
      transform-origin: center;
      z-index: 2;
      animation:
        anchorDropIn 1.1s cubic-bezier(0.18, 0.9, 0.28, 1.2) both,
        anchorFloat 6.8s ease-in-out 1.1s infinite;
    }

    .ocean-logo {
      width: clamp(260px, 25vw, 430px);
      margin-bottom: 0;
      animation: anchorGlow 6.8s ease-in-out 1.1s infinite;
      filter:
        drop-shadow(0 0 16px rgba(255, 216, 74, 0.32))
        drop-shadow(0 0 30px rgba(25, 255, 98, 0.06))
        drop-shadow(0 24px 40px rgba(0, 0, 0, 0.62));
    }

    .ocean-splash-content {
      margin-top: 6px;
      z-index: 3;
    }

    .splash-tagline {
      width: fit-content;
      margin: 0 auto 10px;
      color: var(--gold-bright);
      font-size: clamp(1.18rem, 2.35vw, 1.9rem);
      font-weight: 950;
      letter-spacing: 0.02em;
      text-shadow:
        0 0 10px rgba(255, 216, 74, 0.22),
        0 0 20px rgba(25, 255, 98, 0.07),
        0 12px 38px rgba(0, 0, 0, 0.42);
    }

    .splash-subtagline {
      margin: 0 auto 26px;
      color: rgba(255, 248, 217, 0.72);
      font-size: clamp(0.86rem, 1.3vw, 1.02rem);
      font-weight: 850;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      animation: seaMistFade 7s ease-in-out infinite;
    }

    .splash-subtagline span {
      color: var(--green-bright);
      text-shadow: 0 0 10px rgba(25, 255, 98, 0.28);
    }

    .splash-buttons {
      margin-bottom: 0;
    }

    .bubble {
      position: absolute;
      z-index: 1;
      width: 9px;
      height: 9px;
      border-radius: 999px;
      border: 1px solid rgba(179, 255, 218, 0.26);
      background: rgba(179, 255, 218, 0.05);
      box-shadow: 0 0 14px rgba(25, 255, 98, 0.08);
      pointer-events: none;
      opacity: 0;
    }

    .bubble-one {
      left: 31%;
      bottom: 18%;
      animation: bubbleRise 9s ease-in infinite 0.2s;
    }

    .bubble-two {
      left: 64%;
      bottom: 16%;
      width: 7px;
      height: 7px;
      animation: bubbleRise 10.5s ease-in infinite 2.4s;
    }

    .bubble-three {
      left: 43%;
      bottom: 12%;
      width: 6px;
      height: 6px;
      animation: bubbleRise 8.8s ease-in infinite 4.1s;
    }

    .bubble-four {
      left: 56%;
      bottom: 10%;
      width: 10px;
      height: 10px;
      animation: bubbleRise 11.2s ease-in infinite 5.8s;
    }

    .splash-button {
      transform-origin: center;
    }

    .splash-button:hover {
      animation: buttonHoverWiggle 0.48s ease-in-out both;
    }

    .splash-buttons:not(:hover) .splash-button.discord {
      animation: discordIdleWiggle 3.8s ease-in-out infinite;
    }

    .splash-buttons:hover .splash-button.discord {
      animation: none;
    }

    .splash-buttons:hover .splash-button.discord:hover {
      animation: buttonHoverWiggle 0.48s ease-in-out both;
    }

    @keyframes anchorDropIn {
      0% {
        transform: translateY(-130px) scale(0.96) rotate(-2deg);
        opacity: 0;
      }

      62% {
        transform: translateY(18px) scale(1.01) rotate(0.6deg);
        opacity: 1;
      }

      78% {
        transform: translateY(8px) scale(1) rotate(-0.35deg);
      }

      100% {
        transform: translateY(14px) scale(1) rotate(0deg);
        opacity: 1;
      }
    }

    @keyframes anchorFloat {
      0%,
      100% {
        transform: translateY(14px) rotate(-0.25deg);
      }

      50% {
        transform: translateY(6px) rotate(0.25deg);
      }
    }

    @keyframes anchorGlow {
      0%,
      100% {
        filter:
          drop-shadow(0 0 14px rgba(255, 216, 74, 0.28))
          drop-shadow(0 0 26px rgba(25, 255, 98, 0.05))
          drop-shadow(0 24px 40px rgba(0, 0, 0, 0.62));
      }

      50% {
        filter:
          drop-shadow(0 0 19px rgba(255, 216, 74, 0.36))
          drop-shadow(0 0 36px rgba(25, 255, 98, 0.09))
          drop-shadow(0 26px 42px rgba(0, 0, 0, 0.64));
      }
    }

    @keyframes seaMistFade {
      0%,
      100% {
        opacity: 0.7;
      }

      50% {
        opacity: 0.92;
      }
    }

    @keyframes oceanLightDrift {
      0%,
      100% {
        opacity: 0.62;
        transform: translateX(-1%);
      }

      50% {
        opacity: 0.85;
        transform: translateX(1%);
      }
    }

    @keyframes bubbleRise {
      0% {
        transform: translateY(0) translateX(0) scale(0.75);
        opacity: 0;
      }

      18% {
        opacity: 0.32;
      }

      80% {
        opacity: 0.14;
      }

      100% {
        transform: translateY(-320px) translateX(18px) scale(1.15);
        opacity: 0;
      }
    }

    @keyframes buttonHoverWiggle {
      0% {
        transform: translateY(-2px) rotate(0deg) scale(1);
      }

      18% {
        transform: translateY(-4px) rotate(-1.6deg) scale(1.015);
      }

      36% {
        transform: translateY(-4px) rotate(1.6deg) scale(1.015);
      }

      54% {
        transform: translateY(-4px) rotate(-1deg) scale(1.012);
      }

      72% {
        transform: translateY(-4px) rotate(0.8deg) scale(1.01);
      }

      100% {
        transform: translateY(-4px) rotate(0deg) scale(1.01);
      }
    }

    @keyframes discordIdleWiggle {
      0%,
      78%,
      100% {
        transform: translateY(0) rotate(0deg);
      }

      82% {
        transform: translateY(-1px) rotate(-0.7deg);
      }

      86% {
        transform: translateY(-2px) rotate(0.7deg);
      }

      90% {
        transform: translateY(-1px) rotate(-0.45deg);
      }

      94% {
        transform: translateY(0) rotate(0.35deg);
      }
    }

    @media (max-width: 760px) {
      .ocean-splash {
        padding-top: 12px;
        padding-bottom: 18px;
      }

      .ocean-logo {
        width: min(100%, 340px);
      }

      .ocean-splash-content {
        margin-top: 2px;
      }

      .splash-subtagline {
        margin-bottom: 22px;
      }

      @keyframes anchorDropIn {
        0% {
          transform: translateY(-120px) scale(0.96) rotate(-2deg);
          opacity: 0;
        }

        62% {
          transform: translateY(20px) scale(1.01) rotate(0.6deg);
          opacity: 1;
        }

        78% {
          transform: translateY(10px) scale(1) rotate(-0.35deg);
        }

        100% {
          transform: translateY(16px) scale(1) rotate(0deg);
          opacity: 1;
        }
      }

      @keyframes anchorFloat {
        0%,
        100% {
          transform: translateY(16px) rotate(-0.2deg);
        }

        50% {
          transform: translateY(8px) rotate(0.2deg);
        }
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .ocean-splash::before,
      .ocean-logo,
      .ocean-logo-wrap,
      .splash-subtagline,
      .bubble,
      .splash-button:hover,
      .splash-buttons:not(:hover) .splash-button.discord,
      .splash-buttons:hover .splash-button.discord,
      .splash-buttons:hover .splash-button.discord:hover {
        animation: none;
      }
    }
  </style>
</BaseLayout>