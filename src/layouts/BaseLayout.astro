---
import '../styles/global.css';

const {
  title = 'ElPlugins',
  description = 'For all your Old School Plugin needs.'
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <link rel="icon" type="image/png" href={`${base}images/elpluginshdlogo.png`} />
    <link rel="apple-touch-icon" href={`${base}images/elpluginshdlogo.png`} />
  </head>

  <body>
    <slot />
  </body>
</html>